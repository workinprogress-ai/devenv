// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/dotnet
{
	"name": "WorkInProgress.ai Dev Environment",

	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"image": "mcr.microsoft.com/devcontainers/base:bookworm",
    "remoteEnv": {
        //"NODE_TLS_REJECT_UNAUTHORIZED": "0",
		"DEVCONTAINER": "true",
		"SSH_AUTH_SOCK": "/ssh-agent"
    },

	"mounts": [
		"source=${localEnv:SSH_AUTH_SOCK},target=/ssh-agent,type=bind"
	],

	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	"forwardPorts": [6090],
	"portsAttributes": {
			"6090": {
				"protocol": "http",
				"label": "Desktop Environment"
			}
	},

	"runArgs": [
		// Parameters needed for ZeroTier
		// "--cap-add=NET_ADMIN",
		// "--cap-add=SYS_ADMIN",
		// "--device=/dev/net/tun"
	],
	
    "remoteUser": "vscode",
	"postStartCommand": "/bin/bash .devcontainer/container-start.sh",
	"postCreateCommand": "sudo apt update -y; sudo apt install file -y",

    // Docker extra run args
    // "runArgs": [
    //     "-v",
    //     "${env:SSH_AUTH_SOCK}:/tmp/ssh-agent.socket",
    //     "-e",
    //     "SSH_AUTH_SOCK=/tmp/ssh-agent.socket"
    // ],

    // Features to add to the dev container. More info: https://containers.dev/features.
	"features": {
        "ghcr.io/devcontainers/features/desktop-lite": {
            "webPort": 6090,
            "vncPort": 5091,
            "password": "vscode"
		},
		"ghcr.io/devcontainers/features/docker-in-docker:2": {},
		"ghcr.io/devcontainers/features/node:1": {},
        "ghcr.io/devcontainers/features/github-cli:1": {}
	},

	// Configure tool-specific properties.
	"customizations": {
        "vscode": {
            "extensions": [
                "ms-dotnettools.vscode-dotnet-runtime",
				"ms-dotnettools.csdevkit",
				"ms-vsliveshare.vsliveshare",
				"ms-vscode-remote.remote-ssh",
				"ms-dotnettools.vscode-dotnet-pack",
				"ms-azuretools.vscode-docker",
				
				"rafistatar.addlocalnetreferences",
				"rogalmic.bash-debug",
				"alefragnani.bookmarks",
				"k--kato.docomment",
				"streetsidesoftware.code-spell-checker",
				"ms-vscode-remote.remote-containers",
				"ms-vscode-remote.remote-ssh",
				"ms-dotnettools.vscode-dotnet-pack",
				"eamodio.gitlens",
				"tintoy.msbuild-project-tools",
				"quicktype.quicktype",
				"christian-kohler.path-intellisense",
				"dinhani.divider",
				"wayou.vscode-todo-highlight",
				"fullstackspider.visual-nuget",
				"ms-mssql.mssql",
				"cweijan.vscode-redis-client",
				"mongodb.mongodb-vscode",
				"EditorConfig.EditorConfig",
				"humao.rest-client",
                "dotjoshjohnson.xml",
                "rangav.vscode-thunder-client",
                "simonsiefke.svg-preview",
                "uctakeoff.vscode-counter",
                "pflannery.vscode-versionlens",
                "antmdvs.vscode-react-hooks-snippets",
                "yoavbls.pretty-ts-errors",
                "rvest.vs-code-prettier-eslint",
                "esbenp.prettier-vscode",
                "devine-davies.make-hidden",
                "donjayamanne.githistory",
                "dbaeumer.vscode-eslint",
                "gurayyarar.dummytextgenerator",
				"davidanson.vscode-markdownlint",
				
				"github.copilot",
				"github.copilot-chat",
				"github.vscode-pull-request-github",
				"github.remotehub",
				"github.vscode-github-actions"
			],
            "settings": {
                "github.copilot.chat.additionalReadAccessPaths": [
                    "/workspaces/devenv/repos",
                    "/workspaces/devenv/playground",
                    "/workspaces/devenv/.github",
                    "/workspaces/devenv/tools",
                    "/workspaces/devenv/docs",
                    "/home/vscode",
                    "/tmp"
                ],
                "chat.tools.edits.autoApprove": {
                    "/tmp/**": true,
                    "/workspaces/devenv/playground/**": true
                },
                "chat.tools.terminal.autoApprove": {
                    "run-tests": true,
                    "bash run-tests": true,
                    "git merge-base": true,
                    "git log": true,
                    "git diff": true,
                    "git rev-parse": true,
                    "git branch": true,
                    "git status": true,
                    "git show": true,
                    "git ls-files": true,
                    "git rev-list": true,
                    "git for-each-ref": true,
                    "git cat-file": true,
                    "git shortlog": true,
                    "git name-rev": true,
                    "git describe": true,
                    "git symbolic-ref": true,
                    "git diff-tree": true,
                    "git diff-index": true,
                    "git log -p": true,
                    "git log --stat": true,
                    "git log --name-only": true,
                    "git log --name-status": true,
                    "git log --oneline": true,
                    "git log --graph": true,
                    "pr-threads-get": true,
                    "issue-get": true,
                    "issue-list": true,
                    "pr-get": true,
                    "pr-list": true,
                    "pr-diff": true,
                    "artifacts-list": true,
                    "git-graph": true,
                    "git-graph-all": true,
                    "git-repo": true,
                    "kube-list-pods": true,
                    "kube-logs": true,
                    "metrics-count-code-lines": true,
                    "repo-calc-version": true,
                    "repo-get-web-url": true,
                    "repo-version-list": true,
                    "lint-tools-scripts": true,
                    "get-services-config": true,
                    "lint-documentation": true,
                    "cs-dependencies-trace": true,
                    "markdown-plan-complete-task": true,
                    "markdown-plan-complete-ac": true,
                    "gh issue list": true,
                    "gh issue view": true,
                    "gh issue status": true,
                    "gh pr list": true,
                    "gh pr view": true,
                    "gh pr status": true,
                    "gh pr checks": true,
                    "gh pr diff": true,
                    "gh repo list": true,
                    "gh repo view": true,
                    "gh run list": true,
                    "gh run view": true,
                    "gh workflow list": true,
                    "gh workflow view": true,
                    "gh release list": true,
                    "gh release view": true,
                    "gh label list": true,
                    "gh project list": true,
                    "gh project view": true,
                    "gh project item-list": true,
                    "gh ruleset list": true,
                    "gh ruleset view": true,
                    "gh cache list": true,
                    "gh search repos": true,
                    "gh search issues": true,
                    "gh search prs": true,
                    "gh search commits": true,
                    "gh search code": true,
                    "gh gist list": true,
                    "gh gist view": true,
                    "gh auth status": true,
                    "gh status": true,
                    "find": true,
                    "ls": true,
                    "cat": true,
                    "head": true,
                    "tail": true,
                    "wc": true,
                    "tree": true,
                    "stat": true,
                    "file": true,
                    "grep": true,
                    "rg": true,
                    "jq": true,
                    "awk": true,
                    "cut": true,
                    "sort": true,
                    "uniq": true,
                    "diff": true,
                    "which": true,
                    "command -v": true,
                    "env": true,
                    "printenv": true,
                    "uname": true,
                    "date": true,
                    "whoami": true,
                    "id": true,
                    "ps": true,
                    "lsof": true,
                    "ss": true,
                    "dotnet --info": true,
                    "dotnet --version": true,
                    "dotnet list package": true,
                    "dotnet build":true,
                    "dotnet restore": true,
                    "pnpm list": true,
                    "pnpm outdated": true,
                    "node --version": true,
                    "docker ps": true,
                    "docker images": true,
                    "docker logs": true,
                    "docker inspect": true,
                    "docker version": true
                }
            }
        }
    }
}
